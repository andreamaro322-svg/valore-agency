---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const {
  title = 'Создание сайтов, SEO и GEO-продвижение — Valore Agency',
  description = 'Digital-агентство полного цикла: создание сайтов под ключ, SEO и GEO-продвижение, аудит, разработка логотипов, поддержка сайтов и линкбилдинг. Сделаем сайт заметным в поиске и в нейросетях.',
  canonical = 'https://valoreagency.net/',
  ogImage = 'https://valoreagency.net/og-image.jpg',
} = Astro.props;

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Valore Agency',
  url: 'https://valoreagency.net/',
  logo: 'https://valoreagency.net/logo.svg',
  description: description,
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'sales',
    availableLanguage: ['Russian'],
  },
  sameAs: [
    'https://t.me/PLACEHOLDER',
    'https://wa.me/PLACEHOLDER',
    'https://vk.com/PLACEHOLDER',
  ],
};
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:site_name" content="Valore Agency" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Unbounded:wght@500;600;700&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <style is:global>
      :root {
        --bg: #f7f7f4;
        --ink: #0b1215;
        --ink-60: rgba(11, 18, 21, 0.6);
        --lime: #addf41;
        --lime-soft: #eff9d9;
        --pink: #ffa9e9;
        --pink-soft: #ffeaf9;
        --gray-soft: #f0f0ee;
        --dark: #1c1c1c;
        --border: rgba(0, 0, 0, 0.08);
        --radius: 20px;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        background: var(--bg);
        color: var(--ink);
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
      }

      h1,
      h2,
      h3 {
        font-family: 'Unbounded', sans-serif;
        letter-spacing: -0.02em;
        line-height: 1.1;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        max-width: 100%;
        display: block;
      }

      .container {
        max-width: 1120px;
        margin: 0 auto;
        padding: 0 24px;
      }

      .eyebrow {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--ink-60);
        margin-bottom: 14px;
      }

      .btn {
        display: inline-block;
        padding: 14px 26px;
        border-radius: 12px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.15s ease, opacity 0.15s ease;
        border: 1.5px solid transparent;
      }
      .btn:hover {
        transform: translateY(-2px);
      }
      .btn--dark {
        background: var(--dark);
        color: #fff;
      }
      .btn--lime {
        background: var(--lime);
        color: var(--dark);
      }
      .btn--ghost {
        border-color: var(--dark);
        color: var(--dark);
      }

      section {
        padding: 56px 0;
      }

      @media (prefers-reduced-motion: reduce) {
        * {
          animation: none !important;
          transition: none !important;
          scroll-behavior: auto !important;
        }
      }

      @media (max-width: 720px) {
        section {
          padding: 40px 0;
        }
      }

      /* ============ SHARED COMPONENTS (используются на всех страницах) ============ */

      .section-title {
        font-size: clamp(24px, 4vw, 32px);
        font-weight: 600;
        margin-bottom: 28px;
      }

      /* BREADCRUMB */
      .breadcrumb {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        font-size: 13px;
        color: var(--ink-60);
        padding: 18px 0 0;
      }
      .breadcrumb a {
        color: var(--ink-60);
        transition: color 0.15s ease;
      }
      .breadcrumb a:hover {
        color: var(--ink);
      }
      .breadcrumb span[aria-current] {
        color: var(--ink);
        font-weight: 600;
      }

      /* HERO (внутренние страницы, слева выровнен) */
      .hero {
        position: relative;
        overflow: hidden;
        padding: 48px 0 64px;
      }
      .hero--center {
        text-align: center;
      }
      .hero__blob {
        position: absolute;
        width: 300px;
        height: 300px;
        border-radius: 50%;
        filter: blur(80px);
        opacity: 0.45;
        pointer-events: none;
      }
      .hero__blob--lime {
        background: var(--lime);
        top: -100px;
        left: -40px;
      }
      .hero__blob--pink {
        background: var(--pink);
        top: -60px;
        right: -30px;
      }
      .hero__inner {
        position: relative;
        z-index: 1;
        max-width: 680px;
      }
      .hero--center .hero__inner {
        margin: 0 auto;
        max-width: 640px;
      }
      .hero h1 {
        font-size: clamp(30px, 5.4vw, 44px);
        font-weight: 600;
        margin-top: 4px;
      }
      .hero__lead {
        max-width: 560px;
        margin-top: 18px;
        font-size: 17px;
        color: var(--ink-60);
      }
      .hero--center .hero__lead {
        margin-left: auto;
        margin-right: auto;
      }
      .hero__actions {
        margin-top: 28px;
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
      }
      .hero--center .hero__actions {
        justify-content: center;
      }
      .hero__meta {
        margin-top: 22px;
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
        font-size: 13.5px;
        color: var(--ink-60);
      }
      .hero__meta strong {
        color: var(--ink);
        font-family: 'Unbounded', sans-serif;
        font-weight: 600;
        font-size: 15px;
        display: block;
      }

      /* GRID CARDS: услуги / примеры / карточки-иконки */
      .services {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
      }
      .services--2col {
        grid-template-columns: repeat(2, 1fr);
      }
      .service {
        border-radius: var(--radius);
        padding: 28px;
        min-height: 190px;
        display: flex;
        flex-direction: column;
        transition: transform 0.18s ease;
      }
      a.service:hover {
        transform: translateY(-4px);
      }
      .service__icon {
        font-size: 30px;
        margin-bottom: 12px;
      }
      .service__title {
        font-size: 18px;
        font-weight: 600;
        margin-bottom: 8px;
      }
      .service__text {
        font-size: 13.5px;
        color: var(--ink-60);
        flex-grow: 1;
      }
      .service__more {
        margin-top: 14px;
        font-size: 13px;
        font-weight: 600;
      }
      .service__tag {
        display: inline-block;
        margin-bottom: 10px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--ink-60);
      }

      /* STEPS */
      .steps {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
      }
      .step {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 26px;
      }
      .step__n {
        font-family: 'Unbounded', sans-serif;
        font-size: 30px;
        font-weight: 600;
        color: var(--lime);
        display: block;
        margin-bottom: 12px;
      }
      .step__title {
        font-size: 16px;
        font-weight: 600;
        margin-bottom: 8px;
      }
      .step__text {
        font-size: 13.5px;
        color: var(--ink-60);
      }

      /* PRICING */
      .pricing {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
      }
      .pricing--4col {
        grid-template-columns: repeat(4, 1fr);
      }
      .pricing--2col {
        grid-template-columns: repeat(2, 1fr);
      }
      .price-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 30px;
        display: flex;
        flex-direction: column;
      }
      .price-card--accent {
        border-color: var(--dark);
        box-shadow: 0 0 0 1px var(--dark);
      }
      .price-card__badge {
        align-self: flex-start;
        background: var(--lime);
        color: var(--dark);
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        padding: 4px 10px;
        border-radius: 20px;
        margin-bottom: 12px;
      }
      .price-card__name {
        font-size: 18px;
        font-weight: 600;
        margin-bottom: 10px;
      }
      .price-card__price {
        font-family: 'Unbounded', sans-serif;
        font-size: 26px;
        font-weight: 600;
        color: var(--ink);
        margin-bottom: 12px;
      }
      .price-card__text {
        font-size: 13.5px;
        color: var(--ink-60);
        flex-grow: 1;
        margin-bottom: 20px;
      }
      .price-card__list {
        list-style: none;
        margin: 0 0 20px;
        padding: 0;
        flex-grow: 1;
      }
      .price-card__list li {
        font-size: 13.5px;
        color: var(--ink-60);
        padding-left: 20px;
        position: relative;
        margin-bottom: 8px;
      }
      .price-card__list li::before {
        content: '✓';
        position: absolute;
        left: 0;
        color: var(--lime);
        font-weight: 700;
      }
      .price-card__btn {
        align-self: flex-start;
      }
      .pricing__note {
        margin-top: 20px;
        font-size: 14px;
        color: var(--ink-60);
      }

      /* SEO TEXT / long-form copy */
      .seo-text .container,
      .prose {
        max-width: 820px;
      }
      .seo-text p,
      .prose p {
        font-size: 16px;
        color: var(--ink-60);
        margin-bottom: 16px;
      }
      .seo-text strong,
      .prose strong {
        color: var(--ink);
        font-weight: 600;
      }
      .prose h2 {
        font-size: 24px;
        margin: 32px 0 14px;
      }
      .prose h3 {
        font-size: 18px;
        margin: 24px 0 10px;
      }
      .prose ul {
        margin: 0 0 16px;
        padding-left: 20px;
        color: var(--ink-60);
        font-size: 16px;
      }
      .prose li {
        margin-bottom: 8px;
      }

      /* FAQ */
      .faq {
        max-width: 820px;
      }
      .faq__item {
        border-bottom: 1px solid var(--border);
        padding: 4px 0;
      }
      .faq__q {
        font-family: 'Unbounded', sans-serif;
        font-size: 16px;
        font-weight: 500;
        padding: 18px 0;
        cursor: pointer;
        list-style: none;
        position: relative;
        padding-right: 32px;
      }
      .faq__q::-webkit-details-marker {
        display: none;
      }
      .faq__q::after {
        content: '+';
        position: absolute;
        right: 4px;
        top: 16px;
        font-size: 22px;
        color: var(--lime);
        transition: transform 0.2s ease;
      }
      .faq__item[open] .faq__q::after {
        transform: rotate(45deg);
      }
      .faq__a {
        font-size: 15px;
        color: var(--ink-60);
        padding: 0 32px 20px 0;
      }

      /* CTA / CONTACTS BLOCK */
      .cta__inner {
        position: relative;
        background: var(--dark);
        border-radius: 28px;
        padding: 56px 40px;
        overflow: hidden;
        text-align: center;
      }
      .cta__blob {
        position: absolute;
        width: 320px;
        height: 320px;
        border-radius: 50%;
        background: var(--lime);
        filter: blur(90px);
        opacity: 0.35;
        top: -120px;
        right: -60px;
        pointer-events: none;
      }
      .cta__content {
        position: relative;
        z-index: 1;
        max-width: 520px;
        margin: 0 auto;
      }
      .cta .section-title {
        color: #fff;
      }
      .cta__lead {
        color: rgba(255, 255, 255, 0.7);
        font-size: 16px;
        margin-bottom: 28px;
      }
      .contacts {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
      }
      .contact {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 16px 18px;
        border-radius: 14px;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.14);
        color: #fff;
        font-size: 15px;
        font-weight: 600;
        transition: background 0.15s ease, transform 0.15s ease;
      }
      .contact:hover {
        background: var(--lime);
        color: var(--dark);
        transform: translateY(-2px);
      }
      .contact:focus-visible {
        outline: 2px solid var(--lime);
        outline-offset: 2px;
      }
      .contact__icon {
        width: 22px;
        height: 22px;
        flex-shrink: 0;
      }

      /* PORTFOLIO GRID */
      .portfolio-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
      }
      .portfolio-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
        display: flex;
        flex-direction: column;
      }
      .portfolio-card__cover {
        height: 150px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 34px;
      }
      .portfolio-card__body {
        padding: 22px;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
      }
      .portfolio-card__tag {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--ink-60);
        margin-bottom: 8px;
      }
      .portfolio-card__title {
        font-size: 17px;
        font-weight: 600;
        margin-bottom: 8px;
      }
      .portfolio-card__text {
        font-size: 13.5px;
        color: var(--ink-60);
        flex-grow: 1;
      }
      .portfolio-card__result {
        margin-top: 14px;
        font-size: 12.5px;
        font-weight: 600;
        color: var(--dark);
        background: var(--lime-soft);
        padding: 6px 10px;
        border-radius: 8px;
        display: inline-block;
      }

      /* TESTIMONIALS */
      .testimonials {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
      }
      .testimonial {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 26px;
        display: flex;
        flex-direction: column;
      }
      .testimonial__stars {
        color: var(--lime);
        font-size: 14px;
        margin-bottom: 12px;
        letter-spacing: 2px;
      }
      .testimonial__text {
        font-size: 14.5px;
        color: var(--ink-60);
        flex-grow: 1;
        margin-bottom: 16px;
      }
      .testimonial__author {
        font-size: 14px;
        font-weight: 600;
      }
      .testimonial__role {
        font-size: 12.5px;
        color: var(--ink-60);
      }

      /* RESPONSIVE (общие сетки) */
      @media (max-width: 900px) {
        .services,
        .pricing,
        .portfolio-grid,
        .testimonials {
          grid-template-columns: repeat(2, 1fr);
        }
        .steps {
          grid-template-columns: repeat(2, 1fr);
        }
      }
      @media (max-width: 560px) {
        .services,
        .pricing,
        .pricing--4col,
        .portfolio-grid,
        .testimonials,
        .steps {
          grid-template-columns: 1fr;
        }
        .cta__inner {
          padding: 40px 24px;
        }
      }
    </style>
  </body>
</html>
