---
const navLinks = [
  { href: '/uslugi/sozdanie-sajtov', label: 'Создание сайтов' },
  { href: '/uslugi/seo-geo-prodvizhenie', label: 'SEO / GEO' },
  { href: '/uslugi/audit-sajtov', label: 'Аудит' },
  { href: '/uslugi/razrabotka-logotipov', label: 'Логотипы' },
  { href: '/portfolio', label: 'Портфолио' },
  { href: '/o-nas', label: 'О нас' },
];
---

<header class="header">
  <div class="container header__inner">
    <a href="/" class="logo" aria-label="Valore Agency — на главную">
      Valore<span>.</span>
    </a>

    <nav class="nav" aria-label="Основная навигация">
      {navLinks.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>

    <a href="#zayavka" class="btn btn--lime header__cta">Обсудить проект</a>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(247, 247, 244, 0.9);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }
  .header__inner {
    display: flex;
    align-items: center;
    gap: 24px;
    height: 64px;
  }
  .logo {
    font-family: 'Unbounded', sans-serif;
    font-weight: 700;
    font-size: 22px;
  }
  .logo span {
    color: var(--lime);
  }
  .nav {
    display: flex;
    gap: 20px;
    margin-left: 8px;
    font-size: 14px;
    color: var(--ink-60);
  }
  .nav a {
    transition: color 0.15s ease;
  }
  .nav a:hover {
    color: var(--ink);
  }
  .header__cta {
    margin-left: auto;
    padding: 9px 16px;
    font-size: 13px;
  }

  @media (max-width: 900px) {
    .nav {
      display: none;
    }
    .header__cta {
      margin-left: auto;
    }
  }
</style>
