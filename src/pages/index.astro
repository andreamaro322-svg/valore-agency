---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    icon: '🚀',
    title: 'Создание сайтов',
    text: 'Лендинги, визитки и корпоративные сайты под ключ — быстрые, адаптивные и готовые к продвижению.',
    href: '/uslugi/sozdanie-sajtov',
    bg: 'var(--lime-soft)',
  },
  {
    icon: '🔍',
    title: 'SEO и GEO продвижение',
    text: 'Топ Яндекса и Google по целевым запросам плюс видимость в ИИ-выдаче: ChatGPT, Алиса AI, Gemini.',
    href: '/uslugi/seo-geo-prodvizhenie',
    bg: 'var(--pink-soft)',
  },
  {
    icon: '🩺',
    title: 'Аудит сайтов',
    text: 'Находим технические и SEO-ошибки, показываем точки роста и даём план исправлений.',
    href: '/uslugi/audit-sajtov',
    bg: 'var(--gray-soft)',
  },
  {
    icon: '✳️',
    title: 'Разработка логотипов',
    text: 'Айдентика и логотип, которые выделяют вас среди конкурентов и работают на всех носителях.',
    href: '/uslugi/razrabotka-logotipov',
    bg: 'var(--lime-soft)',
  },
  {
    icon: '🛠️',
    title: 'Поддержка сайтов',
    text: 'Обновления, доработки, мониторинг и техподдержка — ваш сайт всегда работает без сбоев.',
    href: '/uslugi/podderzhka-sajtov',
    bg: 'var(--pink-soft)',
  },
  {
    icon: '🔗',
    title: 'Линкбилдинг',
    text: 'Наращиваем качественную ссылочную массу, повышаем траст домена и позиции в поиске.',
    href: '/uslugi/linkbilding',
    bg: 'var(--gray-soft)',
  },
];

const steps = [
  { n: '01', title: 'Заявка и консультация', text: 'Обсуждаем задачу, цели и объём проекта.' },
  { n: '02', title: 'Договор и план', text: 'Фиксируем сроки, стоимость и этапы работ.' },
  { n: '03', title: 'Работа над проектом', text: 'Дизайн, разработка и оптимизация под поиск.' },
  { n: '04', title: 'Запуск и отчётность', text: 'Публикуем, передаём проект и отчитываемся о результатах.' },
];

const pricing = [
  { name: 'Landing Page', price: 'от 35 000 ₽', text: 'Одностраничный сайт с одной целью — заявка или продажа.' },
  { name: 'Сайт-визитка', price: 'от 37 000 ₽', text: 'Компактный сайт, чтобы презентовать компанию или себя.' },
  { name: 'Корпоративный сайт', price: 'от 45 000 ₽', text: 'Многостраничный сайт для компаний с услугами и разделами.' },
];

const faq = [
  {
    q: 'Сколько стоит создание сайта?',
    a: 'Стоимость зависит от типа сайта: Landing Page — от 35 000 ₽, сайт-визитка — от 37 000 ₽, корпоративный сайт — от 45 000 ₽. Точную цену называем после обсуждения задач на бесплатной консультации.',
  },
  {
    q: 'Что такое GEO-продвижение и чем оно отличается от SEO?',
    a: 'SEO выводит сайт в топ обычной поисковой выдачи Яндекса и Google. GEO (Generative Engine Optimization) делает так, чтобы вас рекомендовали и цитировали нейросети — ChatGPT, Алиса AI, Gemini. Мы занимаемся и тем, и другим.',
  },
  {
    q: 'Сколько времени занимает разработка сайта?',
    a: 'Landing Page — от 3 до 7 дней, сайт-визитка — от 5 до 10 дней, корпоративный сайт — от 2 недель. Точные сроки фиксируем в договоре в зависимости от объёма.',
  },
  {
    q: 'Смогу ли я сам редактировать сайт после сдачи?',
    a: 'Да. Мы передаём вам доступы и при необходимости обучаем работе с сайтом. Также можно подключить нашу услугу поддержки, и правки будем вносить мы.',
  },
  {
    q: 'Делаете ли вы логотип и айдентику?',
    a: 'Да, разработка логотипа и фирменного стиля — отдельная услуга. Можем сделать её как самостоятельно, так и в комплекте с сайтом.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
---

<Layout>
  <!-- HERO -->
  <section class="hero">
    <div class="hero__blob hero__blob--lime"></div>
    <div class="hero__blob hero__blob--pink"></div>
    <div class="container hero__inner">
      <p class="eyebrow">Valore Agency — Digital-агентство полного цикла</p>
      <h1>Сайты, которые находят в поиске и в нейросетях</h1>
      <p class="hero__lead">
        Создаём сайты, выводим в топ Яндекса и Google и делаем заметными для нейросетей.
        Один подрядчик на весь цикл — от идеи до потока заявок.
      </p>
      <div class="hero__actions">
        <a href="#zayavka" class="btn btn--dark">Обсудить проект</a>
        <a href="#uslugi" class="btn btn--ghost">Смотреть услуги</a>
      </div>
    </div>
  </section>

  <!-- УСЛУГИ -->
  <section id="uslugi">
    <div class="container">
      <p class="eyebrow">— Что мы делаем</p>
      <h2 class="section-title">Полный цикл онлайн-присутствия</h2>
      <div class="services">
        {
          services.map((s) => (
            <a class="service" href={s.href} style={`background:${s.bg}`}>
              <span class="service__icon" aria-hidden="true">{s.icon}</span>
              <h3 class="service__title">{s.title}</h3>
              <p class="service__text">{s.text}</p>
              <span class="service__more">Подробнее →</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- СХЕМА РАБОТЫ -->
  <section id="kak-rabotaem">
    <div class="container">
      <p class="eyebrow">— Как мы работаем</p>
      <h2 class="section-title">Схема работы</h2>
      <div class="steps">
        {
          steps.map((step) => (
            <div class="step">
              <span class="step__n">{step.n}</span>
              <h3 class="step__title">{step.title}</h3>
              <p class="step__text">{step.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ЦЕНЫ -->
  <section id="ceny">
    <div class="container">
      <p class="eyebrow">— Прозрачные цены</p>
      <h2 class="section-title">Стоимость создания сайта</h2>
      <div class="pricing">
        {
          pricing.map((p) => (
            <div class="price-card">
              <h3 class="price-card__name">{p.name}</h3>
              <div class="price-card__price">{p.price}</div>
              <p class="price-card__text">{p.text}</p>
              <a href="#zayavka" class="btn btn--ghost price-card__btn">Заказать</a>
            </div>
          ))
        }
      </div>
      <p class="pricing__note">
        Точную стоимость SEO, GEO-продвижения, аудита, логотипа, поддержки и линкбилдинга
        рассчитываем индивидуально после консультации.
      </p>
    </div>
  </section>

  <!-- SEO-ТЕКСТ -->
  <section id="o-uslugah" class="seo-text">
    <div class="container">
      <h2 class="section-title">Создание и продвижение сайтов под ключ</h2>
      <p>
        <strong>Valore Agency</strong> — digital-агентство полного цикла. Мы занимаемся
        созданием сайтов под ключ, их SEO и GEO-продвижением, аудитом, разработкой логотипов,
        поддержкой и линкбилдингом. Вместо нескольких подрядчиков вы работаете с одной командой,
        которая отвечает за результат от первой строчки кода до потока заявок.
      </p>
      <p>
        Мы разрабатываем <strong>сайты для бизнеса</strong> любой сложности: продающие лендинги,
        сайты-визитки и многостраничные корпоративные сайты. Каждый проект изначально проектируется
        под поисковое продвижение — с чистой семантической структурой, быстрой загрузкой, адаптивной
        вёрсткой и корректной микроразметкой. Такой сайт быстро индексируется, занимает высокие
        позиции в Яндексе и Google и приводит целевой трафик.
      </p>
      <p>
        Отдельное направление — <strong>GEO-продвижение (видимость в нейросетях)</strong>. Всё больше
        людей ищут исполнителей не в поиске, а через ChatGPT, Алиса AI и Gemini. Мы структурируем контент
        так, чтобы нейросети находили, понимали и рекомендовали именно вас. Дополняем это классическим
        SEO, линкбилдингом для роста траста домена и регулярной поддержкой, чтобы сайт стабильно
        работал и развивался.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq">
    <div class="container">
      <p class="eyebrow">— Вопросы и ответы</p>
      <h2 class="section-title">Часто задаваемые вопросы</h2>
      <div class="faq">
        {
          faq.map((item) => (
            <details class="faq__item">
              <summary class="faq__q">{item.q}</summary>
              <p class="faq__a">{item.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- СВЯЗАТЬСЯ С НАМИ -->
  <section id="zayavka" class="cta">
    <div class="container cta__inner">
      <div class="cta__blob"></div>
      <div class="cta__content">
        <h2 class="section-title">Связаться с нами</h2>
        <p class="cta__lead">
          Напишите или позвоните удобным способом — ответим, зададим пару вопросов и предложим решение.
        </p>
        <!-- TODO: заменить href на реальные контакты -->
        <div class="contacts">
          <a class="contact" href="tel:+70000000000" aria-label="Позвонить">
            <svg class="contact__icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.4 0 .8-.2 1L6.6 10.8z" fill="currentColor"/>
            </svg>
            <span>Позвонить</span>
          </a>
          <a class="contact" href="https://t.me/PLACEHOLDER" target="_blank" rel="nofollow noopener" aria-label="Написать в Telegram">
            <svg class="contact__icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M21.9 4.3 18.7 19.4c-.2 1-.9 1.3-1.7.8l-4.7-3.5-2.3 2.2c-.3.3-.5.5-1 .5l.3-4.8L18 6.1c.4-.3-.1-.5-.6-.2L7.1 12.5l-4.6-1.4c-1-.3-1-1 .2-1.5L20.6 3c.8-.3 1.6.2 1.3 1.3z" fill="currentColor"/>
            </svg>
            <span>Telegram</span>
          </a>
          <a class="contact" href="https://vk.com/PLACEHOLDER" target="_blank" rel="nofollow noopener" aria-label="Написать во ВКонтакте">
            <svg class="contact__icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M13.2 16.8c-5.4 0-8.9-3.8-9-10h2.8c.1 4.6 2.2 6.5 3.8 6.9V6.8h2.6v3.9c1.6-.2 3.3-2 3.8-3.9h2.6c-.4 2.3-2 4.1-3.2 4.8 1.2.6 3 2.2 3.7 4.2h-2.9c-.5-1.6-2-2.8-3.9-3v3H13.2z" fill="currentColor"/>
            </svg>
            <span>ВКонтакте</span>
          </a>
          <a class="contact" href="https://wa.me/PLACEHOLDER" target="_blank" rel="nofollow noopener" aria-label="Написать в WhatsApp">
            <svg class="contact__icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M12 2a10 10 0 0 0-8.5 15.2L2 22l4.9-1.5A10 10 0 1 0 12 2zm0 2a8 8 0 0 1 6.6 12.5c-.3.4-.4.8-.2 1.2l.4 1.4-1.6-.4c-.4-.1-.8 0-1.1.2A8 8 0 1 1 12 4zm-3 4.2c-.2 0-.5.1-.7.4-.3.3-.9.9-.9 2.1s.9 2.4 1 2.6c.1.2 1.7 2.7 4.2 3.7 2 .8 2.4.7 2.9.6.5-.1 1.5-.6 1.7-1.2.2-.6.2-1.1.1-1.2-.1-.1-.3-.2-.6-.3l-1.5-.7c-.2-.1-.4-.1-.6.1l-.6.8c-.1.2-.3.2-.5.1-.7-.3-1.4-.6-2.1-1.6-.2-.3 0-.4.1-.6l.4-.5c.1-.2.1-.3 0-.5l-.7-1.7c-.2-.4-.4-.4-.6-.4H9z" fill="currentColor"/>
            </svg>
            <span>WhatsApp</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Layout>

<style>
  .section-title {
    font-size: clamp(24px, 4vw, 32px);
    font-weight: 600;
    margin-bottom: 28px;
  }

  /* HERO */
  .hero {
    position: relative;
    overflow: hidden;
    text-align: center;
    padding: 80px 0 64px;
  }
  .hero__blob {
    position: absolute;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.45;
    pointer-events: none;
  }
  .hero__blob--lime {
    background: var(--lime);
    top: -100px;
    left: -40px;
  }
  .hero__blob--pink {
    background: var(--pink);
    top: -60px;
    right: -30px;
  }
  .hero__inner {
    position: relative;
    z-index: 1;
    max-width: 640px;
  }
  .hero h1 {
    font-size: clamp(32px, 6vw, 46px);
    font-weight: 600;
    margin-top: 4px;
  }
  .hero__lead {
    max-width: 500px;
    margin: 20px auto 0;
    font-size: 17px;
    color: var(--ink-60);
  }
  .hero__actions {
    margin-top: 32px;
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* SERVICES */
  .services {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .service {
    border-radius: var(--radius);
    padding: 28px;
    min-height: 190px;
    display: flex;
    flex-direction: column;
    transition: transform 0.18s ease;
  }
  .service:hover {
    transform: translateY(-4px);
  }
  .service__icon {
    font-size: 30px;
    margin-bottom: 12px;
  }
  .service__title {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .service__text {
    font-size: 13.5px;
    color: var(--ink-60);
    flex-grow: 1;
  }
  .service__more {
    margin-top: 14px;
    font-size: 13px;
    font-weight: 600;
  }

  /* STEPS */
  .steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .step {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 26px;
  }
  .step__n {
    font-family: 'Unbounded', sans-serif;
    font-size: 30px;
    font-weight: 600;
    color: var(--lime);
    display: block;
    margin-bottom: 12px;
  }
  .step__title {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .step__text {
    font-size: 13.5px;
    color: var(--ink-60);
  }

  /* PRICING */
  .pricing {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .price-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 30px;
    display: flex;
    flex-direction: column;
  }
  .price-card__name {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 10px;
  }
  .price-card__price {
    font-family: 'Unbounded', sans-serif;
    font-size: 26px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 12px;
  }
  .price-card__text {
    font-size: 13.5px;
    color: var(--ink-60);
    flex-grow: 1;
    margin-bottom: 20px;
  }
  .price-card__btn {
    align-self: flex-start;
  }
  .pricing__note {
    margin-top: 20px;
    font-size: 14px;
    color: var(--ink-60);
  }

  /* SEO TEXT */
  .seo-text .container {
    max-width: 820px;
  }
  .seo-text p {
    font-size: 16px;
    color: var(--ink-60);
    margin-bottom: 16px;
  }
  .seo-text strong {
    color: var(--ink);
    font-weight: 600;
  }

  /* FAQ */
  .faq {
    max-width: 820px;
  }
  .faq__item {
    border-bottom: 1px solid var(--border);
    padding: 4px 0;
  }
  .faq__q {
    font-family: 'Unbounded', sans-serif;
    font-size: 16px;
    font-weight: 500;
    padding: 18px 0;
    cursor: pointer;
    list-style: none;
    position: relative;
    padding-right: 32px;
  }
  .faq__q::-webkit-details-marker {
    display: none;
  }
  .faq__q::after {
    content: '+';
    position: absolute;
    right: 4px;
    top: 16px;
    font-size: 22px;
    color: var(--lime);
    transition: transform 0.2s ease;
  }
  .faq__item[open] .faq__q::after {
    transform: rotate(45deg);
  }
  .faq__a {
    font-size: 15px;
    color: var(--ink-60);
    padding: 0 32px 20px 0;
  }

  /* CTA */
  .cta__inner {
    position: relative;
    background: var(--dark);
    border-radius: 28px;
    padding: 56px 40px;
    overflow: hidden;
    text-align: center;
  }
  .cta__blob {
    position: absolute;
    width: 320px;
    height: 320px;
    border-radius: 50%;
    background: var(--lime);
    filter: blur(90px);
    opacity: 0.35;
    top: -120px;
    right: -60px;
    pointer-events: none;
  }
  .cta__content {
    position: relative;
    z-index: 1;
    max-width: 520px;
    margin: 0 auto;
  }
  .cta .section-title {
    color: #fff;
  }
  .cta__lead {
    color: rgba(255, 255, 255, 0.7);
    font-size: 16px;
    margin-bottom: 28px;
  }
  .contacts {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  .contact {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 16px 18px;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.14);
    color: #fff;
    font-size: 15px;
    font-weight: 600;
    transition: background 0.15s ease, transform 0.15s ease;
  }
  .contact:hover {
    background: var(--lime);
    color: var(--dark);
    transform: translateY(-2px);
  }
  .contact:focus-visible {
    outline: 2px solid var(--lime);
    outline-offset: 2px;
  }
  .contact__icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .services,
    .pricing {
      grid-template-columns: repeat(2, 1fr);
    }
    .steps {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 560px) {
    .services,
    .pricing,
    .steps {
      grid-template-columns: 1fr;
    }
    .cta__inner {
      padding: 40px 24px;
    }
  }
</style>
